---
import "../styles/tailwind.css";
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.tsx";
interface Props { title: string }
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <h1><a href={base}>Paper Library</a></h1>
        <span class="masthead-tag">· a reading room for agent research</span>
        <nav><a href={base}>Papers</a> <a href={`${base}knowledge/`.replace(/\/+/g, "/")}>Knowledge</a> <ThemeToggle client:load /></nav>
      </div>
    </header>
    <main class="wrap"><slot /></main>
  </body>
</html>
