---
import Base from "../layouts/Base.astro";
import Catalog from "../components/Catalog.tsx";
import { loadCatalog } from "../lib/catalog";
const papers = loadCatalog().filter((p) => p.summary_path).map((p) => ({
  canonical_key: p.canonical_key, title: p.title, authors: p.authors, year: p.year,
  venue: p.venue, tags: p.tags, topic_groups: p.topic_groups,
  triage_label: p.triage_label, score: p.score,
}));
const base = import.meta.env.BASE_URL;
---
<Base title="Paper Library — Catalog">
  <h1 class="title">Paper Library</h1>
  <p class="count">{papers.length} papers with summaries.</p>
  <Catalog client:load papers={papers} base={base} />
</Base>
